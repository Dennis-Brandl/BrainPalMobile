{
  "expo": {
    "name": "BrainPal Mobile",
    "slug": "brainpal-mobile",
    "version": "0.0.1",
    "scheme": "brainpal-mobile",
    "orientation": "portrait",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
